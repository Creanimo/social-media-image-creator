<div class="creations wa-stack">
    <h2>Creations & Templates</h2>

    <wa-tab-group>
        <wa-tab slot="nav" panel="my-creations" active>My Creations</wa-tab>
        <wa-tab slot="nav" panel="preset-templates">Preset Templates</wa-tab>

        <wa-tab-panel name="my-creations">
            <div class="wa-stack">
                <div class="wa-cluster" style="--max-column-size: 300px">
                    {{#creations}}
                    <wa-card>
                         <div slot="header">Creation: {{title}}{{^title}}{{id}}{{/title}}</div>
                         <p>Size: {{width}}x{{height}}</p>
                         <p>Layers: {{layers.length}}</p>
                         <div slot="footer">
                            <wa-button variant="primary" data-id="{{id}}" class="edit-btn">Edit</wa-button>
                            <wa-button variant="danger" data-id="{{id}}" class="delete-btn">Delete</wa-button>
                         </div>
                    </wa-card>
                    {{/creations}}
                    {{^creations}}
                    <p>No creations yet.</p>
                    {{/creations}}
                </div>
                <wa-button id="create-new" variant="primary">Create New Creation</wa-button>
            </div>
        </wa-tab-panel>

        <wa-tab-panel name="preset-templates">
            <div class="wa-cluster" style="--max-column-size: 300px">
                {{#presets}}
                <wa-card>
                     <div slot="header">Template: {{title}}{{^title}}{{id}}{{/title}}</div>
                     <p>Size: {{width}}x{{height}}</p>
                     <p>Layers: {{layers.length}}</p>
                     <div slot="footer">
                        <wa-button variant="primary" data-id="{{id}}" class="use-preset-btn">Use Template</wa-button>
                     </div>
                </wa-card>
                {{/presets}}
                {{^presets}}
                <p>No preset templates found.</p>
                {{/presets}}
            </div>
        </wa-tab-panel>
    </wa-tab-group>
</div>
